generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String?          @unique
  name            String?
  island          String?
  projects        Project[]
  advisorSessions AdvisorSession[]
  subscription    Subscription?
  orders          Order[]
  createdAt       DateTime         @default(now())
  ContractorLead  ContractorLead[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  tier             String    @default("free") // free | pro | builder
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  status           String    @default("active")
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Order {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  type             String // lead | estimate_single | estimate_full | boq | boq_hardware | boq_quotes | permit_prep | contract | tax_appeal
  amount           Int // in cents
  status           String            @default("pending") // pending | paid | delivered | refunded
  stripePaymentId  String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  estimateResult   EstimateResult?
  boqResultV2      BOQResultV2?
  boqQuoteRequests BOQQuoteRequest[]
  contractorLeads  ContractorLead[]
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  island      String
  projectType String
  stage       Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Guide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  island    String   @default("all")
  excerpt   String
  content   String   @db.Text
  imageUrl  String?
  order     Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Contractor {
  id            String               @id @default(cuid())
  name          String
  trade         String
  island        String
  phone         String?
  email         String?
  website       String?
  description   String?
  imageUrl      String?
  verified      Boolean              @default(false)
  featuredTier  String? // null | basic | featured | premium
  monthlyFee    Int? // in cents
  stripeSubId   String?
  listingStatus String               @default("active")
  interests     ContractorInterest[]
}

model AdvisorSession {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractorLead {
  id              String               @id @default(cuid())
  orderId         String?
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  projectBrief    Json
  island          String
  tradesNeeded    String[]
  budget          String?
  timeline        String?
  contractorsSent String[]
  interests       ContractorInterest[]
  status          String               @default("sent") // sent | interested | fulfilled
  createdAt       DateTime             @default(now())
  Order           Order?               @relation(fields: [orderId], references: [id])
}

// Tracks when a contractor expresses interest — client only sees contact AFTER this
model ContractorInterest {
  id             String         @id @default(cuid())
  leadId         String
  lead           ContractorLead @relation(fields: [leadId], references: [id])
  contractorId   String
  contractor     Contractor     @relation(fields: [contractorId], references: [id])
  notifiedAt     DateTime       @default(now())
  clientNotified Boolean        @default(false)
}

model Partner {
  id           String         @id @default(cuid())
  businessName String
  category     String
  contactName  String
  email        String
  phone        String?
  website      String?
  logoUrl      String?
  description  String?
  island       String
  tier         String         @default("basic")
  monthlyFee   Int
  stripeSubId  String?
  active       Boolean        @default(false)
  approved     Boolean        @default(false)
  referralCode String         @unique
  referralCount Int           @default(0)
  adPlacements PartnerAd[]
  referrals    PartnerReferral[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model PartnerAd {
  id         String   @id @default(cuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id])
  placement  String
  headline   String
  tagline    String?
  ctaText    String?
  ctaUrl     String
  logoUrl    String?
  monthlyFee Int
  stripeSubId String?
  active     Boolean  @default(false)
  impressions Int     @default(0)
  clicks     Int      @default(0)
  createdAt  DateTime @default(now())
}

model PartnerReferral {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id])
  userId       String?
  referralCode String
  page         String
  converted    Boolean  @default(false)
  fee          Int?
  createdAt    DateTime @default(now())
}

model PriceList {
  id          String   @id @default(cuid())
  itemCode    String   @unique
  itemName    String
  unit        String
  unitPrice   Float
  supplier    String?
  lastUpdated DateTime @default(now())
  updatedBy   String?
  notes       String?
}

model BOQResultV2 {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id])
  userId       String
  fileUrl      String?
  dimensions   Json
  assessment   Json
  lineItems    Json
  summary      Json
  reportUrl    String?
  confidenceHigh  Float   @default(0)
  confidenceMed   Float   @default(0)
  confidenceLow   Float   @default(0)
  totalLow     Float?
  totalHigh    Float?
  createdAt    DateTime @default(now())
}

model HardwareStore {
  id          String             @id @default(cuid())
  name        String
  island      String
  email       String
  phone       String?
  contactName String?
  tier        String             @default("free") // free | listed | premium
  monthlyFee  Int?
  stripeSubId String?
  active      Boolean            @default(true)
  responses   BOQQuoteResponse[]
  createdAt   DateTime           @default(now())
}

model BOQQuoteRequest {
  id           String             @id @default(cuid())
  orderId      String
  order        Order              @relation(fields: [orderId], references: [id])
  boqData      Json
  storesSentTo String[]
  responses    BOQQuoteResponse[]
  status       String             @default("pending") // pending | responses_received | delivered
  sentAt       DateTime           @default(now())
  deadlineAt   DateTime
  createdAt    DateTime           @default(now())
}

model BOQQuoteResponse {
  id          String          @id @default(cuid())
  requestId   String
  request     BOQQuoteRequest @relation(fields: [requestId], references: [id])
  storeId     String
  store       HardwareStore   @relation(fields: [storeId], references: [id])
  priceData   Json
  totalAmount Int?
  receivedAt  DateTime        @default(now())
}

model EstimateResult {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  userId     String
  fileUrl    String?
  brief      Json
  result     String   @db.Text
  resultType String // estimate | boq | boq_hardware
  createdAt  DateTime @default(now())
}

model AdvisorCache {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  embedding Json? // stored as JSON array of floats (text-embedding-3-small, 1536 dims)
  category  String?
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  lastHitAt DateTime @default(now())
}

model PexelsCache {
  id           String   @id @default(cuid())
  query        String   @unique
  resourceType String
  data         Json
  createdAt    DateTime @default(now())
}
