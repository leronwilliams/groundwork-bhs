generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  island          String?
  projects        Project[]
  advisorSessions AdvisorSession[]
  createdAt       DateTime         @default(now())
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  island      String
  projectType String
  stage       Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Guide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  island    String   @default("all")
  excerpt   String
  content   String   @db.Text
  imageUrl  String?
  order     Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Contractor {
  id           String  @id @default(cuid())
  name         String
  trade        String
  island       String
  phone        String?
  email        String?
  website      String?
  verified     Boolean @default(false)
  featuredTier String?
  description  String?
  imageUrl     String?
}

model AdvisorCache {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  embedding Json?    // stored as JSON array of floats (text-embedding-3-small, 1536 dims)
  category  String?
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  lastHitAt DateTime @default(now())
}

model PexelsCache {
  id           String   @id @default(cuid())
  query        String   @unique
  resourceType String
  data         Json
  createdAt    DateTime @default(now())
}

model AdvisorSession {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
